{
  "name": "desktop-for-yoto",
  "version": "0.1.2",
  "description": "Drag-and-drop audio onto Yoto MYO cards.",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "dev": "npm run build && electron .",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "ffmpeg-static": "^5.3.0",
    "yoto-nodejs-client": "0.0.11"
  },
  "build": {
    "appId": "co.samuelmillett.desktop-for-yoto",
    "productName": "Desktop for Yoto",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/onnxruntime-node/**",
      "**/node_modules/@huggingface/**"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models"
      }
    ],
    "files": [
      "dist/**",
      "package.json",
      "node_modules/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "sjaym88",
      "repo": "desktop-for-yoto"
    }
  }
}
